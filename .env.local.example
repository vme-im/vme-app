# ========================================
# GitHub OAuth 应用配置（登录功能必需）
# ========================================
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ========================================
# NextAuth 配置（登录功能必需）
# ========================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret

# ========================================
# Cloudflare R2 配置（梗图上传功能）
# ========================================
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=vme-images
R2_PUBLIC_URL=https://img.example.com

# ========================================
# GitHub Token（匿名用户查看公开 Issue/Reactions 用）
# ========================================
# 创建方式：GitHub Settings → Developer settings → Fine-grained tokens
# 权限：Public Repositories (read-only)
# 不配也可：未登录用户的点赞/详情请求会返回 503，登录用户走自己的 OAuth token 不受影响
GITHUB_TOKEN=github_pat_xxx

# ========================================
# 快照源（可选）
# ========================================
# 默认从 https://raw.githubusercontent.com/vme-im/vme-content/main 拉 data/snapshot.sql，
# 匿名 IP 有限速——Vercel 多 Lambda 并发冷启动会 429。生产建议指向 jsDelivr CDN：
#   SNAPSHOT_BASE_URL=https://cdn.jsdelivr.net/gh/vme-im/vme-content@main
# 秒级生效：vme-content 侧 push 后主动清 CDN 缓存
#   curl https://purge.jsdelivr.net/gh/vme-im/vme-content@main/data/snapshot.sql
# 调试时也可指向本地或备份镜像
# SNAPSHOT_BASE_URL=https://raw.githubusercontent.com/vme-im/vme-content/main
